<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia12WasmThreads.Views.MainView">
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Margin="10" Spacing="10">
      <Button x:Name="RunBtn" Content="Run State Machine" Click="OnRun"/>
      <TextBlock x:Name="Status" VerticalAlignment="Center"/>
    </StackPanel>
    <Canvas x:Name="Arena" Grid.Row="1" Background="#1a1a2e"/>
    <TextBlock x:Name="Log" Grid.Row="2" Margin="10" FontSize="11"
               MaxHeight="80" Foreground="Gray"/>
  </Grid>
</UserControl>
